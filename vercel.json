{
  "version": 2,
  "builds": [
    {
      "src": "nephub/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "build_files.sh",
      "use": "@vercel/static-build",
      "config": { "distDir": "staticfiles" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "nephub/wsgi.py" }
  ]
}
